# photo-indexer 환경변수 (모두 선택사항, 기본값은 ~/.photo-indexer.*)

# DB 경로
# PHOTO_INDEX_DB=~/.photo-indexer.db

# 설정 파일 경로
# PHOTO_INDEX_CONF=~/.photo-indexer.conf

# YOLO 모델 경로
# PHOTO_INDEX_YOLO_MODEL=~/yolov8n.pt

# YOLO confidence 임계값 (0.0~1.0)
# PHOTO_INDEX_YOLO_CONF=0.3

# 썸네일 캐시 디렉토리
# PHOTO_INDEX_THUMBS=~/.photo-indexer-thumbs
# PHOTO_INDEX_FACE_THUMBS=~/.photo-indexer-face-thumbs
